# Copy to .env.local and adjust for your environment.
# Restart `npm run dev` after changing.

VITE_API_BASE_URL=https://teamdev.seewework.com/api

# Optional: origin that serves uploaded files (photos, certificates, agreements).
# Defaults to the API host minus `/api`. Override it to load files from a
# different host than the API (e.g. API local, files on the live server).
# VITE_ASSET_BASE_URL=https://teamdev.seewework.com
